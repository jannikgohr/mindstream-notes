{
  "version": 1,
  "categories": [
    {
      "id": "account",
      "icon": "user-round",
      "sections": [
        {
          "id": "account.server",
          "settings": [
            {
              "id": "account.serverType",
              "scope": "V",
              "type": "radio",
              "default": "local-only",
              "options": ["managed", "self-hosted", "local-only"]
            },
            {
              "id": "account.managedUnavailable",
              "scope": "V",
              "type": "info",
              "showIf": { "id": "account.serverType", "equals": "managed" }
            },
            {
              "id": "account.signInForm",
              "scope": "V",
              "type": "custom",
              "customId": "sign-in-form",
              "showIf": {
                "id": "account.serverType",
                "notEquals": "local-only"
              }
            }
          ]
        },
        {
          "id": "account.sync",
          "settings": [
            {
              "id": "account.syncEnabled",
              "scope": "V",
              "type": "toggle",
              "default": true
            },
            {
              "id": "account.syncInterval",
              "scope": "V",
              "type": "select",
              "default": "live",
              "options": ["live", "1m", "5m", "15m", "manual"],
              "showIf": { "id": "account.syncEnabled", "equals": true }
            }
          ]
        }
      ]
    },
    {
      "id": "general",
      "icon": "settings",
      "sections": [
        {
          "id": "general.behavior",
          "settings": [
            {
              "id": "general.startOnLogin",
              "scope": "D",
              "type": "toggle",
              "default": false,
              "platforms": ["desktop"]
            },
            {
              "id": "general.closeToTray",
              "scope": "D",
              "type": "toggle",
              "default": false,
              "platforms": ["desktop"]
            },
            {
              "id": "general.startInTray",
              "scope": "D",
              "type": "toggle",
              "default": false,
              "platforms": ["desktop"],
              "showIf": { "id": "general.startOnLogin", "equals": true }
            }
          ]
        }
      ]
    },
    {
      "id": "appearance",
      "icon": "palette",
      "sections": [
        {
          "id": "appearance.theme",
          "settings": [
            {
              "id": "appearance.mode",
              "scope": "D",
              "type": "radio",
              "default": "system",
              "options": ["light", "dark", "system"]
            },
            {
              "id": "appearance.accent",
              "scope": "V",
              "type": "color",
              "default": "#0a0a0a"
            },
            {
              "id": "appearance.reduceMotion",
              "scope": "D",
              "type": "radio",
              "default": "system",
              "options": ["on", "off", "system"]
            },
            {
              "id": "appearance.customWindowDecorations",
              "scope": "D",
              "type": "toggle",
              "default": true,
              "defaultByPlatform": { "macos": false },
              "platforms": ["desktop"]
            }
          ]
        },
        {
          "id": "appearance.typography",
          "settings": [
            {
              "id": "appearance.uiFontSize",
              "scope": "V",
              "type": "slider",
              "default": 16,
              "min": 12,
              "max": 18,
              "step": 1,
              "unit": "px"
            },
            {
              "id": "appearance.editorFontSize",
              "scope": "V",
              "type": "slider",
              "default": 16,
              "min": 12,
              "max": 24,
              "step": 1,
              "unit": "px"
            },
            {
              "id": "appearance.lineHeight",
              "scope": "V",
              "type": "slider",
              "default": 1.6,
              "min": 1.2,
              "max": 2.0,
              "step": 0.05
            }
          ]
        },
        {
          "id": "appearance.fileTree",
          "settings": [
            {
              "id": "appearance.sortStrategy",
              "scope": "D",
              "type": "radio",
              "default": "alphabetical",
              "options": ["alphabetical", "modified", "created"]
            },
            {
              "id": "appearance.foldersFirst",
              "scope": "V",
              "type": "toggle",
              "default": true
            }
          ]
        }
      ]
    },
    {
      "id": "editor",
      "icon": "pencil-line",
      "sections": [
        {
          "id": "editor.input",
          "settings": [
            {
              "id": "editor.defaultMode",
              "scope": "V",
              "type": "radio",
              "default": "wysiwyg",
              "options": ["wysiwyg", "source", "split"]
            },
            {
              "id": "editor.tabSize",
              "scope": "V",
              "type": "number",
              "default": 2,
              "min": 1,
              "max": 8
            },
            {
              "id": "editor.autoPair",
              "scope": "V",
              "type": "toggle",
              "default": true
            },
            {
              "id": "editor.trimTrailing",
              "scope": "V",
              "type": "toggle",
              "default": true
            },
            {
              "id": "editor.desktopToolbar",
              "scope": "D",
              "type": "toggle",
              "default": true,
              "platforms": ["desktop"]
            }
          ]
        },
        {
          "id": "editor.markdown",
          "settings": [
            {
              "id": "editor.math",
              "scope": "V",
              "type": "toggle",
              "default": true
            },
            {
              "id": "editor.mermaid",
              "scope": "V",
              "type": "toggle",
              "default": true
            },
            {
              "id": "editor.wikilinks",
              "scope": "V",
              "type": "toggle",
              "default": true
            },
            {
              "id": "editor.wikilinkOpenOnClick",
              "scope": "V",
              "type": "toggle",
              "default": true,
              "showIf": { "id": "editor.wikilinks", "equals": true }
            },
            {
              "id": "editor.footnotes",
              "scope": "V",
              "type": "toggle",
              "default": true
            }
          ]
        },
        {
          "id": "editor.freeform",
          "settings": [
            {
              "id": "editor.freeform.penMode",
              "scope": "V",
              "type": "select",
              "default": "auto",
              "options": ["auto", "always", "off"]
            }
          ]
        },
        {
          "id": "editor.ink",
          "settings": [
            {
              "id": "editor.ink.tool",
              "scope": "D",
              "type": "select",
              "default": "pen",
              "options": ["pen", "eraser", "lasso"]
            },
            {
              "id": "editor.ink.color",
              "scope": "D",
              "type": "color",
              "default": "#000000"
            },
            {
              "id": "editor.ink.width",
              "scope": "D",
              "type": "slider",
              "default": 4,
              "min": 0.5,
              "max": 12,
              "step": 0.5,
              "unit": "pu"
            },
            {
              "id": "editor.ink.eraserMode",
              "scope": "D",
              "type": "select",
              "default": "stroke",
              "options": ["stroke", "pixel"]
            },
            {
              "id": "editor.ink.fingerDrawing",
              "scope": "D",
              "type": "toggle",
              "default": true
            },
            {
              "id": "editor.ink.pageTheme",
              "scope": "D",
              "type": "select",
              "default": "light",
              "options": ["light", "dark", "system"]
            },
            {
              "id": "editor.ink.pageBackground",
              "scope": "D",
              "type": "select",
              "default": "clear",
              "options": ["clear", "points", "lines", "grid"]
            },
            {
              "id": "editor.ink.pageBackgroundColor",
              "scope": "D",
              "type": "color",
              "default": "#334155",
              "showIf": {
                "id": "editor.ink.pageBackground",
                "notEquals": "clear"
              }
            },
            {
              "id": "editor.ink.pageBackgroundOpacity",
              "scope": "D",
              "type": "slider",
              "default": 100,
              "min": 0,
              "max": 100,
              "step": 5,
              "unit": "%",
              "showIf": {
                "id": "editor.ink.pageBackground",
                "notEquals": "clear"
              }
            }
          ]
        },
        {
          "id": "editor.autosave",
          "settings": [
            {
              "id": "editor.autoSave",
              "scope": "V",
              "type": "toggle",
              "default": true
            },
            {
              "id": "editor.autoSaveDebounce",
              "scope": "V",
              "type": "slider",
              "default": 800,
              "min": 100,
              "max": 5000,
              "step": 100,
              "unit": "ms",
              "showIf": { "id": "editor.autoSave", "equals": true }
            }
          ]
        }
      ]
    },
    {
      "id": "hotkeys",
      "icon": "keyboard",
      "platforms": ["desktop"],
      "sections": [
        {
          "id": "hotkeys.list",
          "settings": [
            {
              "id": "hotkeys.globalShortcuts",
              "scope": "D",
              "type": "toggle",
              "default": false,
              "platforms": ["desktop"]
            },
            {
              "id": "hotkeys.panel",
              "scope": "D",
              "type": "custom",
              "customId": "hotkeys-panel"
            }
          ]
        }
      ]
    },
    {
      "id": "data",
      "icon": "database",
      "sections": [
        {
          "id": "data.database",
          "settings": [
            {
              "id": "data.openFolder",
              "scope": "V",
              "type": "button",
              "actionId": "open-data-folder"
            }
          ]
        },
        {
          "id": "data.trash",
          "settings": [
            {
              "id": "data.trashRetentionDays",
              "scope": "V",
              "type": "select",
              "default": "30",
              "options": ["7", "30", "90", "forever"]
            },
            {
              "id": "data.emptyTrash",
              "scope": "V",
              "type": "button",
              "variant": "destructive",
              "actionId": "empty-trash"
            }
          ]
        },
        {
          "id": "data.backup",
          "settings": [
            {
              "id": "data.backupNow",
              "scope": "V",
              "type": "button",
              "actionId": "backup-now"
            },
            {
              "id": "data.restoreBackup",
              "scope": "V",
              "type": "button",
              "actionId": "restore-backup"
            },
            {
              "id": "data.exportVault",
              "scope": "V",
              "type": "button",
              "actionId": "export-vault"
            },
            {
              "id": "data.importNotes",
              "scope": "V",
              "type": "button",
              "actionId": "import-notes"
            }
          ]
        },
        {
          "id": "data.history",
          "settings": [
            {
              "id": "data.historyRetentionDays",
              "scope": "V",
              "type": "select",
              "default": "90",
              "options": ["7", "30", "90", "365", "forever"]
            }
          ]
        },
        {
          "id": "data.historyAdvanced",
          "advanced": true,
          "settings": [
            {
              "id": "data.historyIdleSeconds",
              "scope": "V",
              "type": "slider",
              "default": 180,
              "min": 30,
              "max": 600,
              "step": 30,
              "unit": "s"
            },
            {
              "id": "data.historyTokenThreshold",
              "scope": "V",
              "type": "slider",
              "default": 200,
              "min": 50,
              "max": 2000,
              "step": 50
            }
          ]
        }
      ]
    },
    {
      "id": "language",
      "icon": "languages",
      "sections": [
        {
          "id": "language.locale",
          "settings": [
            {
              "id": "language.code",
              "scope": "D",
              "type": "select",
              "default": "en",
              "options": ["en", "de"]
            }
          ]
        }
      ]
    },
    {
      "id": "about",
      "icon": "info",
      "sections": [
        {
          "id": "about.version",
          "settings": [
            { "id": "about.appVersion", "scope": "D", "type": "info" },
            { "id": "about.tauriVersion", "scope": "D", "type": "info" },
            {
              "id": "about.scanForUpdates",
              "scope": "D",
              "type": "toggle",
              "default": true,
              "platforms": ["desktop"]
            },
            {
              "id": "about.checkUpdates",
              "scope": "D",
              "type": "button",
              "actionId": "check-updates"
            }
          ]
        }
      ]
    }
  ]
}
