{
  "version": 1,
  "categories": [
    {
      "id": "account",
      "icon": "user-round",
      "sections": [
        {
          "id": "account.server",
          "settings": [
            {
              "id": "account.serverType",
              "scope": "G",
              "type": "radio",
              "default": "local-only",
              "options": ["managed", "self-hosted", "local-only"]
            },
            {
              "id": "account.serverUrl",
              "scope": "G",
              "type": "text",
              "default": "",
              "placeholder": "https://notes.example.com",
              "showIf": { "id": "account.serverType", "equals": "self-hosted" }
            },
            {
              "id": "account.signInForm",
              "scope": "G",
              "type": "custom",
              "customId": "sign-in-form",
              "showIf": { "id": "account.serverType", "notEquals": "local-only" }
            },
            {
              "id": "account.collabServerUrl",
              "scope": "G",
              "type": "text",
              "default": "",
              "placeholder": "wss://collab.example.com",
              "showIf": { "id": "account.serverType", "notEquals": "local-only" }
            }
          ]
        },
        {
          "id": "account.sync",
          "settings": [
            { "id": "account.syncEnabled", "scope": "V", "type": "toggle", "default": false },
            {
              "id": "account.syncInterval",
              "scope": "V",
              "type": "select",
              "default": "live",
              "options": ["live", "1m", "5m", "15m", "manual"],
              "showIf": { "id": "account.syncEnabled", "equals": true }
            },
            {
              "id": "account.conflict",
              "scope": "V",
              "type": "radio",
              "default": "ask",
              "options": ["ask", "prefer-local", "prefer-remote", "keep-both"],
              "showIf": { "id": "account.syncEnabled", "equals": true }
            }
          ]
        }
      ]
    },
    {
      "id": "general",
      "icon": "settings",
      "sections": [
        {
          "id": "general.behavior",
          "settings": [
            {
              "id": "general.startOnLogin",
              "scope": "D",
              "type": "toggle",
              "default": false
            }
          ]
        }
      ]
    },
    {
      "id": "appearance",
      "icon": "palette",
      "sections": [
        {
          "id": "appearance.theme",
          "settings": [
            {
              "id": "appearance.mode",
              "scope": "D",
              "type": "radio",
              "default": "system",
              "options": ["light", "dark", "system"]
            },
            { "id": "appearance.accent", "scope": "V", "type": "color", "default": "#0a0a0a" },
            {
              "id": "appearance.density",
              "scope": "V",
              "type": "select",
              "default": "cozy",
              "options": ["compact", "cozy", "roomy"]
            },
            { "id": "appearance.reduceMotion", "scope": "D", "type": "toggle", "default": false }
          ]
        },
        {
          "id": "appearance.typography",
          "settings": [
            {
              "id": "appearance.uiFontSize",
              "scope": "V",
              "type": "slider",
              "default": 14,
              "min": 12,
              "max": 18,
              "step": 1,
              "unit": "px"
            },
            {
              "id": "appearance.editorFontSize",
              "scope": "V",
              "type": "slider",
              "default": 16,
              "min": 12,
              "max": 24,
              "step": 1,
              "unit": "px"
            },
            {
              "id": "appearance.lineHeight",
              "scope": "V",
              "type": "slider",
              "default": 1.6,
              "min": 1.2,
              "max": 2.0,
              "step": 0.05
            }
          ]
        },
        {
          "id": "appearance.fileTree",
          "settings": [
            {
              "id": "appearance.sortStrategy",
              "scope": "V",
              "type": "radio",
              "default": "alphabetical",
              "options": ["alphabetical", "modified", "created"]
            },
            { "id": "appearance.foldersFirst", "scope": "V", "type": "toggle", "default": true }
          ]
        }
      ]
    },
    {
      "id": "editor",
      "icon": "pencil-line",
      "sections": [
        {
          "id": "editor.input",
          "settings": [
            {
              "id": "editor.defaultMode",
              "scope": "V",
              "type": "radio",
              "default": "wysiwyg",
              "options": ["wysiwyg", "source", "split"]
            },
            { "id": "editor.vimMode", "scope": "V", "type": "toggle", "default": false },
            {
              "id": "editor.tabSize",
              "scope": "V",
              "type": "number",
              "default": 2,
              "min": 1,
              "max": 8
            },
            { "id": "editor.autoPair", "scope": "V", "type": "toggle", "default": true },
            { "id": "editor.trimTrailing", "scope": "V", "type": "toggle", "default": true }
          ]
        },
        {
          "id": "editor.markdown",
          "settings": [
            { "id": "editor.math", "scope": "V", "type": "toggle", "default": true },
            { "id": "editor.mermaid", "scope": "V", "type": "toggle", "default": true },
            { "id": "editor.wikilinks", "scope": "V", "type": "toggle", "default": true },
            { "id": "editor.footnotes", "scope": "V", "type": "toggle", "default": true }
          ]
        },
        {
          "id": "editor.autosave",
          "settings": [
            { "id": "editor.autoSave", "scope": "V", "type": "toggle", "default": true },
            {
              "id": "editor.autoSaveDebounce",
              "scope": "V",
              "type": "slider",
              "default": 500,
              "min": 100,
              "max": 5000,
              "step": 100,
              "unit": "ms",
              "showIf": { "id": "editor.autoSave", "equals": true }
            }
          ]
        }
      ]
    },
    {
      "id": "data",
      "icon": "database",
      "sections": [
        {
          "id": "data.database",
          "settings": [
            {
              "id": "data.databasePath",
              "scope": "V",
              "type": "path",
              "mode": "file",
              "default": ""
            },
            { "id": "data.openFolder", "scope": "V", "type": "button", "actionId": "open-data-folder" }
          ]
        },
        {
          "id": "data.trash",
          "settings": [
            { "id": "data.useTrash", "scope": "V", "type": "toggle", "default": true },
            {
              "id": "data.trashRetentionDays",
              "scope": "V",
              "type": "select",
              "default": "30",
              "options": ["7", "30", "90", "forever"],
              "showIf": { "id": "data.useTrash", "equals": true }
            },
            {
              "id": "data.emptyTrash",
              "scope": "V",
              "type": "button",
              "variant": "destructive",
              "actionId": "empty-trash"
            }
          ]
        },
        {
          "id": "data.backup",
          "settings": [
            { "id": "data.backupEnabled", "scope": "V", "type": "toggle", "default": true },
            {
              "id": "data.backupSchedule",
              "scope": "V",
              "type": "select",
              "default": "daily",
              "options": ["daily", "weekly", "manual"],
              "showIf": { "id": "data.backupEnabled", "equals": true }
            },
            { "id": "data.backupNow", "scope": "V", "type": "button", "actionId": "backup-now" },
            {
              "id": "data.exportVault",
              "scope": "V",
              "type": "button",
              "actionId": "export-vault"
            },
            {
              "id": "data.importNotes",
              "scope": "V",
              "type": "button",
              "actionId": "import-notes"
            }
          ]
        }
      ]
    },
    {
      "id": "privacy",
      "icon": "shield",
      "sections": [
        {
          "id": "privacy.telemetry",
          "settings": [
            { "id": "privacy.usageStats", "scope": "G", "type": "toggle", "default": false },
            { "id": "privacy.crashReports", "scope": "G", "type": "toggle", "default": true },
            { "id": "privacy.clearCache", "scope": "D", "type": "button", "actionId": "clear-cache" }
          ]
        }
      ]
    },
    {
      "id": "language",
      "icon": "languages",
      "sections": [
        {
          "id": "language.locale",
          "settings": [
            {
              "id": "language.code",
              "scope": "D",
              "type": "select",
              "default": "en",
              "options": ["en", "de"]
            }
          ]
        }
      ]
    },
    {
      "id": "about",
      "icon": "info",
      "sections": [
        {
          "id": "about.version",
          "settings": [
            { "id": "about.appVersion", "scope": "G", "type": "info" },
            { "id": "about.tauriVersion", "scope": "G", "type": "info" },
            { "id": "about.checkUpdates", "scope": "G", "type": "button", "actionId": "check-updates" }
          ]
        }
      ]
    }
  ]
}
