node_modules
/.pnpm-store
/.output
/dist

# Playwright
/playwright/.cache
.DS_Store
.env
.env.*
!.env.example
# Committed on purpose: throwaway, deterministic creds for the disposable
# T4 test stack (backend/docker-compose.test.yml). Local-only, never prod.
!backend/.env.test

# Cached T4 e2e account credentials (throwaway signups on the local test
# stack, reused across runs — see e2e-tests/app/helpers/accounts.ts).
/e2e-tests/app/helpers/.t4-accounts.json

# Tauri
/src-tauri/target
/src-tauri/gen/schemas
# Cargo.lock is intentionally committed for src-tauri: it's a binary
# crate (the app), and reproducible builds need a pinned dependency
# graph. The "don't commit Cargo.lock" guidance applies to libraries
# only — see https://doc.rust-lang.org/cargo/faq.html#why-do-binaries-have-cargolock-in-version-control-but-not-libraries
# Generated at install / before each build by src-tauri/scripts/setup-android-cargo.mjs.
# It needs absolute paths (cargo doesn't resolve relative paths in build-script overrides),
# so it can't be committed.
/src-tauri/.cargo/config.toml
/src-tauri/.pkgconfig
## Tauri signer
.tauri

# Sandbox-leftover artifacts that the workspace mount won't let me delete.
# Safe to remove these directories on Windows when convenient.
/.git.locked
/_tmp_*

# IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
*.iml

# Keys
keystore.jks
