{
  "name": "mindstream-notes",
  "private": true,
  "version": "0.1.8",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm build:ink-web && vite dev",
    "build": "pnpm build:ink-web && vite build",
    "build:ink-web": "rustup target add wasm32-unknown-unknown && wasm-pack build crates/ink-egui-web --target web --out-dir ../../src/lib/ink-web/pkg --out-name ink_egui_web",
    "preview": "vite preview",
    "check": "pnpm build:ink-web && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "pnpm build:ink-web && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri-dev": "tauri dev",
    "tauri-build": "tauri build",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm check && pnpm test && pnpm build",
    "verify:rust": "cd src-tauri && cargo test",
    "setup-android-cargo": "node src-tauri/scripts/setup-android-cargo.mjs",
    "postinstall": "node src-tauri/scripts/setup-android-cargo.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/svelte": "^5.2.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "happy-dom": "^15.11.0",
    "husky": "^9.1.7",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.0",
    "wasm-pack": "^0.15.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@milkdown/crepe": "^7.5.8",
    "@milkdown/kit": "^7.5.8",
    "@milkdown/plugin-collab": "^7.20.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "~2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "bits-ui": "1.0.0-next.78",
    "clsx": "^2.1.1",
    "dockview-core": "^6.4.0",
    "lucide-svelte": "^0.469.0",
    "mermaid": "^11.15.0",
    "mode-watcher": "^0.5.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^2.6.0",
    "tailwind-variants": "^0.3.0",
    "tldraw": "^5.0.1",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  }
}
