{
  "name": "mindstream-notes",
  "private": true,
  "version": "0.1.12",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "node src-tauri/scripts/tauri.mjs",
    "tauri-dev": "node src-tauri/scripts/tauri.mjs dev",
    "tauri-build": "node src-tauri/scripts/tauri.mjs build",
    "test": "svelte-kit sync && vitest run",
    "test:watch": "vitest",
    "test:coverage": "svelte-kit sync && vitest run --coverage",
    "test:e2e": "svelte-kit sync && playwright test --config e2e/browser/playwright.config.ts",
    "test:e2e:ui": "playwright test --config e2e/browser/playwright.config.ts --ui",
    "test:e2e:backend": "playwright test --config e2e/backend/playwright.config.ts",
    "test:e2e:app": "wdio run e2e/app/wdio.conf.ts",
    "test:e2e:app:multi": "wdio run e2e/app/wdio.multiremote.conf.ts",
    "backend:test:up": "node backend/scripts/test-stack.mjs up",
    "backend:test:down": "node backend/scripts/test-stack.mjs down",
    "backend:test:reset": "node backend/scripts/test-stack.mjs reset",
    "backend:test:logs": "node backend/scripts/test-stack.mjs logs",
    "backend:test:status": "node backend/scripts/test-stack.mjs status",
    "verify": "pnpm check && pnpm test && pnpm build",
    "verify:rust": "cd src-tauri && cargo test",
    "test:coverage:rust": "node src-tauri/scripts/rust-coverage.mjs",
    "format": "pnpm run format:web && pnpm run format:rust",
    "format:check": "pnpm run format:web:check && pnpm run format:rust:check",
    "format:web": "node src-tauri/scripts/format-web.mjs",
    "format:web:check": "node src-tauri/scripts/format-web.mjs --check",
    "format:rust": "node src-tauri/scripts/format-rust.mjs",
    "format:rust:check": "node src-tauri/scripts/format-rust.mjs --check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,svelte,json,html,css,md}": [
      "prettier --check"
    ]
  },
  "devDependencies": {
    "@codemirror/language": "6.12.3",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/svelte": "^5.2.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "etebase": "^0.43.1",
    "expect-webdriverio": "^5.7.0",
    "happy-dom": "^15.11.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "prosemirror-model": "1.25.9",
    "prosemirror-state": "1.4.4",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@floating-ui/dom": "^1.7.6",
    "@jis3r/icons": "^2.7.0",
    "@lucide/svelte": "^1.20.0",
    "@milkdown/core": "^7.21.2",
    "@milkdown/crepe": "^7.21.2",
    "@milkdown/ctx": "^7.21.2",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/plugin-collab": "^7.21.2",
    "@milkdown/plugin-diff": "^7.21.2",
    "@milkdown/prose": "^7.21.2",
    "@milkdown/transformer": "^7.21.2",
    "@milkdown/utils": "^7.21.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "~2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "bits-ui": "1.0.0-next.78",
    "clsx": "^2.1.1",
    "dockview-core": "^6.4.0",
    "image-js": "^1.6.2",
    "mermaid": "^11.15.0",
    "mode-watcher": "^0.5.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "perfect-freehand": "^1.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.6.0",
    "tailwind-variants": "^0.3.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  }
}
