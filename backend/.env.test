# Mindstream Notes — pinned config for the disposable T4 test stack.
#
# These are THROWAWAY credentials for a local, disposable e2e backend that
# is only reachable on localhost:${NGINX_PORT}. They are committed on
# purpose so the stack is deterministic and needs no manual .env step — do
# NOT reuse them for anything real. Bring the stack up with
# `pnpm backend:test:up` (loads this file via --env-file).

# Single host the client + provisioning helper talk to.
PUBLIC_HOST=localhost
PUBLIC_ORIGIN=http://localhost:18080

# Postgres (etebase backing store) — internal to the compose network.
POSTGRES_DB=etebase
POSTGRES_USER=etebase
POSTGRES_PASSWORD=mindstream-test-postgres

# etebase Django superuser — pinned (not random) so tests are deterministic.
ETEBASE_SUPER_USER=admin
ETEBASE_SUPER_PASS=mindstream-test-admin

# Host port the test nginx edge is published on. Kept off 8080 so a dev
# stack (docker-compose.override.yml) can run at the same time.
NGINX_PORT=18080
