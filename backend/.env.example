# Mindstream Notes — backend stack config.
# Copy to .env and edit before `docker compose up`.

# Host port the nginx edge listens on. The compose maps NGINX_PORT:80.
# Put your TLS-terminating proxy in front of this; the stack itself is
# plain HTTP.
NGINX_PORT=8080

# CORS allow-list passed through to excalidraw-room. `*` is fine when a
# trusted upstream proxy already gates origins; otherwise set to the
# exact origin of your client (e.g. https://notes.example.com).
EXCALIDRAW_CORS_ORIGIN=*
