# Mindstream Notes — backend stack config.
# Copy to .env and edit before `docker compose up`.

# ─── Public identity ─────────────────────────────────────────────────
# The client talks to ONE host: nginx path-routes the notes API and
# both WebSocket collab transports off the same origin. So you set the
# host in exactly one place and everything downstream derives from it.
#
# PUBLIC_HOST — the hostname only (no scheme, no port). Drives etebase's
# ALLOWED_HOSTS and CSRF_TRUSTED_ORIGINS. Django matches the host
# without the port, so leave any :port off here.
#   Local dev:   localhost
#   Production:  notes.example.com   (or a wildcard like *.example.com)
PUBLIC_HOST=localhost

# PUBLIC_ORIGIN — the full origin (scheme + host [+ port]) the client
# loads from. Used for the excalidraw-room CORS allow-list. In
# production this is simply https://<PUBLIC_HOST>; the default below
# matches the local-dev override that publishes nginx on :8080.
#   Local dev:   http://localhost:8080
#   Production:  https://notes.example.com
PUBLIC_ORIGIN=http://localhost:8080

# ─── Postgres (etebase backing store) ────────────────────────────────
# POSTGRES_PASSWORD is required — compose refuses to start without it.
# The other two are safe to leave at the defaults; they only matter
# inside the docker network and aren't reachable from outside.
POSTGRES_DB=etebase
POSTGRES_USER=etebase
POSTGRES_PASSWORD=change-me-please

# ─── etebase ─────────────────────────────────────────────────────────
# Django superuser created on first boot. Used to access /admin and to
# bootstrap signups when AUTO_SIGNUP isn't on.
ETEBASE_SUPER_USER=admin

# Leave blank to let the image generate a random super-user password
# and print it to the container logs on first boot:
#   docker compose logs etebase | grep -i password
# Grab it once, store it in your password manager, and rotate later
# from the /admin UI. Set this only if you need a known-up-front
# password — it lives in the env afterwards.
ETEBASE_SUPER_PASS=

# ─── Local dev only ──────────────────────────────────────────────────
# Host port docker-compose.override.yml publishes nginx on. Ignored in
# production (deploy tooling doesn't load the override file). Keep this
# in sync with the :port in PUBLIC_ORIGIN above.
NGINX_PORT=8080
